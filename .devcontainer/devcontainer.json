{
    "name": "backup",
    "build": {
        "dockerfile": "Containerfile",
        "context": "..",
        "target": "project"
    },
    "remoteUser": "developer",
    "containerUser": "developer",
    "updateRemoteUserUID": true,
    "runArgs": [
        "--name=${localWorkspaceFolderBasename}-dev",
        "--userns=keep-id",
        "--security-opt=no-new-privileges"
    ],
    // These paths are relative to the wsl-sys-cli parent repo
    "workspaceFolder": "/workspace/linux/backup",
    "workspaceMount": "source=${localWorkspaceFolder}/../..,target=/workspace,type=bind",
    "mounts": [
        // ~/my/kb
        "type=bind,source=${localEnv:HOME}/my/kb,target=/home/developer/kb",
        // project
        "type=bind,source=${localEnv:HOME}/.config/wsl-backup,target=/home/developer/.config/wsl-backup",
        // golang
        "type=volume,target=/home/developer/.cache",
        "type=volume,target=/home/developer/go"
    ],
    "postCreateCommand": "[ -f /tmp/.zsh_history ] && cp /tmp/.zsh_history /home/developer/.zsh_history || true",
    "customizations": {
        "vscode": {
            "extensions": [
                "davidanson.vscode-markdownlint",
                "golang.go"
            ]
        }
    }
}